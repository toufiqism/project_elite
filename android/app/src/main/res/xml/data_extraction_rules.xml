<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup + device-transfer policy.
  We intentionally exclude everything: user data syncs via Firebase /
  Firestore, not Android Backup. Including local Hive boxes here would
  resurrect deleted auth tokens and cached API keys.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
